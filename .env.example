# co-be — environment config
#
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Both agent_v2/__init__.py and agent_v3/__init__.py auto-load .env on import.
# v3's model resolver falls back from AGENT_V3_* to AGENT_V2_* names.

# ====== REQUIRED ======
OPENAI_API_KEY=sk-...

# ====== MODEL CHOICE (optional) ======
AGENT_V2_OPENAI_MODEL=gpt-4.1-mini

# Override the v3 model independently (uncomment to use a different model for Agno).
# AGENT_V3_OPENAI_MODEL=gpt-4.1-mini

# Optional writer-only override (falls back to AGENT_V*_OPENAI_MODEL when unset).
# AGENT_V2_WRITER_MODEL=gpt-4.1
# AGENT_V3_WRITER_MODEL=gpt-4.1

# ====== OPTIONAL ======
# Only needed for hosted LangGraph Studio UI (v2). Not required for local dev or uvicorn.
# LANGSMITH_API_KEY=lsv2_...

# Verbose stderr logs (skill/tool/cart) + full SSE event logging in uvicorn.
AGENT_V2_DEBUG=false
